+#ifdef __MVS__
+/* Encoding conversion functions for z/OS */
+
+/* Parse encoding string and determine conversion mode */
+encoding_mode_t encoding_parse_mode(const char *encoding_str)
+{
+  /* Explicit NULL check at function start */
+  if(!encoding_str)
+    return ENCODING_NONE;
+    
+  if(!strcasecmp(encoding_str, "auto"))
+    return ENCODING_AUTO;
+  else if(!strcasecmp(encoding_str, "binary"))
+    return ENCODING_BINARY;
+  else if(!strcasecmp(encoding_str, "ascii") || 
+          !strcasecmp(encoding_str, "e2a"))
+    return ENCODING_E2A;
+  else if(!strcasecmp(encoding_str, "a2e"))
+    return ENCODING_A2E;
+  else
+    return ENCODING_ICONV;
+}
+
+/* Get CCSID from encoding string */
+unsigned short encoding_get_ccsid(const char *encoding_str)
+{
+  if(!encoding_str)
+    return 0;
+    
+  if(!strcasecmp(encoding_str, "auto"))
+    return 0;
+  else if(!strcasecmp(encoding_str, "binary"))
+    return 65535;
+  else if(!strcasecmp(encoding_str, "ascii") || 
+          !strcasecmp(encoding_str, "e2a"))
+    return 819;  /* ISO 8859-1 (ASCII-compatible) */
+  else if(!strcasecmp(encoding_str, "a2e"))
+    return 1047; /* IBM EBCDIC */
+  else {
+    unsigned short ccsid = __toCcsid((char*)encoding_str);
+    return ccsid;
+  }
+}
+
+/* Initialize encoding context from encoding string */
+int encoding_init(encoding_ctx_t *ctx, const char *encoding_str, 
+                  int is_upload)
+{
+  if(!ctx)
+    return -1;
+    
+  memset(ctx, 0, sizeof(encoding_ctx_t));
+  
+  ctx->mode = encoding_parse_mode(encoding_str);
+  ctx->ccsid = encoding_get_ccsid(encoding_str);
+  
+  if(!is_upload && encoding_str) {
+    /* For downloads, if the user requested ASCII/819, we don't need conversion
+       because the network data is already ASCII. We only need to tag it. */
+    if(ctx->mode == ENCODING_E2A || ctx->ccsid == 819) {
+      ctx->mode = ENCODING_NONE;
+    }
+  }
+
+  if(ctx->mode == ENCODING_ICONV && encoding_str) {
+    if(is_upload) {
+      ctx->from_encoding = strdup("IBM-1047");
+      ctx->to_encoding = strdup(encoding_str);
+    }
+    else {
+      /* Download: Network (ISO8859-1) -> User Requested Encoding */
+      ctx->from_encoding = strdup("ISO8859-1");
+      ctx->to_encoding = strdup(encoding_str);
+    }
+    
+    if(!ctx->from_encoding || !ctx->to_encoding) {
+      encoding_cleanup(ctx);
+      return -1;
+    }
+    
+    /* If source and target encodings are the same, no conversion is needed */
+    if(!strcasecmp(ctx->from_encoding, ctx->to_encoding)) {
+      encoding_cleanup(ctx);
+      ctx->mode = ENCODING_NONE;
+      return 0;
+    }
+    
+    iconv_t cd = iconv_open(ctx->to_encoding, ctx->from_encoding);
+    if(cd == (iconv_t)-1) {
+      encoding_cleanup(ctx);
+      return -1;
+    }
+    ctx->iconv_cd = (void*)cd;
+  }
+  
+  return 0;
+}
+
+/* Convert buffer using encoding context */
+int encoding_convert(encoding_ctx_t *ctx, char *buffer, size_t *size,
+                     size_t max_size)
+{
+  if(!ctx || !buffer || !size)
+    return -1;
+    
+  switch(ctx->mode) {
+  case ENCODING_NONE:
+  case ENCODING_AUTO:
+  case ENCODING_BINARY:
+    return 0;
+    
+  case ENCODING_E2A:
+    __e2a_s(buffer);
+    return 0;
+    
+  case ENCODING_A2E:
+    __a2e_s(buffer);
+    return 0;
+    
+  case ENCODING_ICONV: {
+    if(!ctx->iconv_cd)
+      return -1;
+      
+    iconv_t cd = (iconv_t)ctx->iconv_cd;
+    char *outbuf = malloc(max_size);
+    if(!outbuf)
+      return -1;
+    
+    /* Save original buffer content in case conversion fails */
+    char *backup_buffer = malloc(*size);
+    if(!backup_buffer) {
+      free(outbuf);
+      return -1;
+    }
+    memcpy(backup_buffer, buffer, *size);
+      
+    char *inptr = buffer;
+    char *outptr = outbuf;
+    size_t inleft = *size;
+    size_t outleft = max_size;
+    
+    /* Reset conversion state */
+    iconv(cd, NULL, NULL, NULL, NULL);
+    size_t result = iconv(cd, &inptr, &inleft, &outptr, &outleft);
+    
+    if(result == (size_t)-1) {
+      /* Conversion failed - restore original buffer */
+      memcpy(buffer, backup_buffer, *size);
+      free(backup_buffer);
+      free(outbuf);
+      return -1;
+    }
+    
+    /* Conversion succeeded - copy converted data to buffer */
+    size_t converted_size = max_size - outleft;
+    memcpy(buffer, outbuf, converted_size);
+    *size = converted_size;
+    
+    free(backup_buffer);
+    free(outbuf);
+    return 0;
+  }
+  }
+  
+  return -1;
+}
+
+/* Clean up encoding context */
+void encoding_cleanup(encoding_ctx_t *ctx)
+{
+  if(!ctx)
+    return;
+    
+  if(ctx->from_encoding) {
+    free(ctx->from_encoding);
+    ctx->from_encoding = NULL;
+  }
+  
+  if(ctx->to_encoding) {
+    free(ctx->to_encoding);
+    ctx->to_encoding = NULL;
+  }
+  
+  if(ctx->iconv_cd) {
+    iconv_close((iconv_t)ctx->iconv_cd);
+    ctx->iconv_cd = NULL;
+  }
+  
+  memset(ctx, 0, sizeof(encoding_ctx_t));
+}
+#endif /* __MVS__ */
+
